# Copy to .env and fill in. .env is gitignored — never commit real keys.

# football-data.org free tier (covers World Cup). Get free key: https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=

# The Odds API — OPTIONAL, decide after backtest. https://the-odds-api.com/
# Free=NBA/MLB only. Pro $29 = soccer live. Business $99 = Pinnacle + historical archive.
ODDS_API_KEY=

# Kaggle — for historical datasets. Or place kaggle.json at ~/.kaggle/kaggle.json
KAGGLE_USERNAME=
KAGGLE_KEY=

# Polymarket Gamma API — no key needed for read-only.
# Open-Meteo weather — no key needed.
